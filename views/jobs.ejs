<%- include("partials/head.ejs") %>
<%- include("partials/header.ejs") %>

<h2>Jobs List</h2>

    <table id="jobs-table">
      <tr id="jobs-table-header">
        <th>Company</th>
        <th>Position</th>
        <th>Status</th>
        <th colspan="2"></th>
      </tr>
      <% if (jobs && jobs.length) { %>
        <% jobs.forEach((job) => { %>
          <tr>
            <td><%= job.company %></td>
            <td><%= job.position %></td>
            <td><%= job.status %></td>
            <td><button type="button">edit</button></td>
            <td>button type="button">delete</button></td>
          </tr>
        <% }) %>
      <% } %>
    </table>



<h2>Jobs List</h2>

<a href="/jobs/new">
  <button type="button">Add New Job</button>
</a>

<table>
  <tr>
    <th>Company</th>
    <th>Position</th>
    <th>Status</th>
    <th colspan="2"></th>
  </tr>

  <% if (jobs && jobs.length) { %>
    <% jobs.forEach(job => { %>
      <tr>
        <td><%= job.company %></td>
        <td><%= job.position %></td>
        <td><%= job.status %></td>

        <!-- Edit Button (GET request) -->
        <td>
          <a href="/jobs/edit/<%= job._id %>">
            <button type="button">edit</button>
          </a>
        </td>

        <!-- Delete Button (POST request with CSRF) -->
        <td>
          <form method="POST" action="/jobs/delete/<%= job._id %>" style="display:inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button>delete</button>
          </form>
        </td>
      </tr>
    <% }) %>
  <% } %>
</table>

<%- include("partials/footer.ejs") %>