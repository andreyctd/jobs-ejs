<%- include("partials/head.ejs") %>
<%- include("partials/header.ejs") %>

<h2><%= job ? "Edit Job" : "Add Job" %></h2>

<form method="POST" action="<%= job ? '/jobs/update/' + job._id : '/jobs' %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <div>
    <label>Company:</label>
    <input name="company" value="<%= job ? job.company : '' %>">
  </div>

  <div>
    <label>Position:</label>
    <input name="position" value="<%= job ? job.position : '' %>">
  </div>

  <div>
    <label>Status:</label>
    <input name="status" value="<%= job ? job.status : '' %>">
  </div>

  <button type="submit">
    <%= job ? "Update" : "Create" %>
  </button>
</form>

<%- include("partials/footer.ejs") %>